# Telegram Bot API Token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# AssemblyAI API Key
ASSEMBLYAI_API_KEY=YOUR_ASSEMBLYAI_API_KEY

# Local Telegram Bot API (Optional, for files > 20MB)
USE_LOCAL_API=False
LOCAL_API_URL=http://telegram-api:8081
API_ID=YOUR_TELEGRAM_API_ID
API_HASH=YOUR_TELEGRAM_API_HASH
LOCAL_API_VOLUME_PATH=/var/lib/telegram-bot-api

# Lava.top API Key (billing is currently disabled, but required in config)
LAVATOP_API_KEY=YOUR_LAVATOP_API_KEY
OFFER_ID_60=
OFFER_ID_300=
OFFER_ID_600=

# Канал для проверки подписки
CHANNEL_ID=@e_mysienko
CHANNEL_URL=https://t.me/e_mysienko

# Лимиты файлов
MAX_FILE_SIZE_MB=200
MAX_STORAGE_GB=10
